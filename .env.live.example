# ==================================================================
# .env.live — פלטפורמה חיה
# ==================================================================
# מלא/י את הערכים וקרא/י לקובץ .env.live (בלי .example), ואז הרץ/י:
#   ./scripts/go-live.sh
# הקובץ .env.live נכלל ב-.gitignore ולעולם לא מסתנכרן ל-git.
# ==================================================================

# Supabase — חובה
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# אופציונלי — מחרוזת חיבור ישירה ל-Postgres (לצורך הרצת schema.sql דרך psql)
# מצא/י ב-Supabase → Settings → Database → Connection string → URI
SUPABASE_DB_URL=
SUPABASE_STORAGE_BUCKET=uploads

# Admin — חובה לפרודקשן
ADMIN_TOKEN=
ADMIN_EMAIL=

# SMTP (Gmail App Password מומלץ)
SMTP_USER=
SMTP_PASS=

# WhatsApp דרך CallMeBot — אופציונלי
CALLMEBOT_API_KEY=
ORGANIZER_WA_NUMBER=
